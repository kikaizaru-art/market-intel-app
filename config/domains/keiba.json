{
  "domain": "keiba",
  "name": "競馬分析",
  "version": "0.1.0",
  "description": "レース結果・馬場状態・血統・騎手成績を多層収集し、回収率パターンを自動蓄積",

  "layers": {
    "macro": {
      "label": "マクロ環境",
      "description": "JRA全体の売上推移・馬場状態・天候・開催情報",
      "collectors": ["jra-schedule", "weather", "news-rss"],
      "sources": {
        "jra-schedule": {
          "provider": "jra-van",
          "dataPoints": ["race_calendar", "track_condition", "total_sales"]
        },
        "weather": {
          "provider": "openweathermap",
          "locations": ["tokyo", "kyoto", "hanshin", "nakayama", "chukyo"]
        },
        "news-rss": {
          "feeds": [
            { "name": "netkeiba", "url": "https://news.netkeiba.com/rss/index.xml" },
            { "name": "スポニチ競馬", "url": "https://www.sponichi.co.jp/gamble/rss/index.xml" },
            { "name": "競馬ラボ", "url": "https://www.keibalab.jp/rss/" }
          ]
        }
      }
    },
    "competitor": {
      "label": "出走馬・騎手",
      "description": "各馬の過去成績・調教データ・騎手成績・血統情報",
      "collectors": ["jra-results", "training-data"],
      "sources": {
        "jra-results": {
          "provider": "jra-van",
          "dataPoints": [
            "race_result", "horse_profile", "jockey_stats",
            "trainer_stats", "pedigree"
          ]
        },
        "training-data": {
          "provider": "jra-van",
          "dataPoints": ["workout_time", "condition_comment"]
        }
      }
    },
    "user": {
      "label": "市場心理",
      "description": "オッズ推移・SNS予想の偏り・予想家の見解",
      "collectors": ["odds-tracker", "sns-sentiment"],
      "sources": {
        "odds-tracker": {
          "provider": "jra-van",
          "metrics": ["win_odds", "place_odds", "exacta_odds"],
          "trackInterval": "10min"
        },
        "sns-sentiment": {
          "platforms": ["twitter", "5ch"],
          "keywords": []
        }
      }
    },
    "causal": {
      "label": "因果関係",
      "description": "馬場×血統×距離→回収率パターンの自動蓄積",
      "autoMemo": true,
      "validationEnabled": true,
      "learningEnabled": true
    }
  },

  "targets": [
    {
      "id": "g1-races",
      "name": "GIレース",
      "category": "重賞",
      "identifiers": {
        "grade": "G1"
      }
    }
  ],

  "categories": ["GI", "GII", "GIII", "オープン", "条件戦"],

  "seasonalPatterns": [
    { "month": 1,  "event": "中山金杯・京都金杯 (開幕週)",          "impact": "neutral",  "layer": "macro" },
    { "month": 2,  "event": "フェブラリーS (ダートGI)",             "impact": "positive", "layer": "macro" },
    { "month": 3,  "event": "高松宮記念・大阪杯",                  "impact": "positive", "layer": "macro" },
    { "month": 4,  "event": "桜花賞・皐月賞 (クラシック開幕)",      "impact": "positive", "layer": "macro" },
    { "month": 5,  "event": "NHKマイルC・オークス・ダービー",       "impact": "positive", "layer": "macro" },
    { "month": 6,  "event": "安田記念・宝塚記念 (春G1最終)",       "impact": "positive", "layer": "macro" },
    { "month": 7,  "event": "夏競馬開始 (ローカル中心)",            "impact": "negative", "layer": "macro" },
    { "month": 9,  "event": "秋競馬開幕 (中山・阪神)",              "impact": "positive", "layer": "macro" },
    { "month": 10, "event": "秋華賞・菊花賞・天皇賞秋",            "impact": "positive", "layer": "macro" },
    { "month": 11, "event": "エリザベス女王杯・マイルCS・JC",      "impact": "positive", "layer": "macro" },
    { "month": 12, "event": "有馬記念 (年末最大売上)",              "impact": "positive", "layer": "macro" }
  ],

  "analysis": {
    "anomalyThreshold": 2.0,
    "trendWindow": 4,
    "causationWindowDays": 0,
    "autoConfirmThreshold": 0.60,
    "autoRejectThreshold": 0.35
  },

  "keiba": {
    "trackConditions": ["良", "稍重", "重", "不良"],
    "distances": [1000, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2500, 3000, 3200, 3600],
    "courses": ["東京", "中山", "阪神", "京都", "中京", "小倉", "新潟", "福島", "札幌", "函館"],
    "surfaceTypes": ["芝", "ダート"]
  },

  "dataPrefix": "keiba"
}

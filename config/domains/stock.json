{
  "domain": "stock",
  "name": "株式市場分析",
  "version": "0.1.0",
  "description": "個別銘柄・セクターの多層環境変数を収集し、因果パターンを蓄積",

  "layers": {
    "macro": {
      "label": "マクロ環境",
      "description": "金利・為替・セクター指数・経済指標",
      "collectors": ["stock-index", "economic-indicators", "news-rss"],
      "sources": {
        "stock-index": {
          "indices": ["N225", "TOPIX", "SP500"],
          "provider": "yahoo-finance"
        },
        "economic-indicators": {
          "metrics": ["USD_JPY", "CPI_JP", "BOJ_RATE"],
          "provider": "fred"
        },
        "news-rss": {
          "feeds": [
            { "name": "日経", "url": "https://www.nikkei.com/rss/index.xml" },
            { "name": "Reuters JP", "url": "https://jp.reuters.com/rssFeed/topNews" },
            { "name": "Bloomberg JP", "url": "https://www.bloomberg.co.jp/rss/sitemap_news.xml" }
          ]
        }
      }
    },
    "competitor": {
      "label": "同業他社",
      "description": "同業他社の決算・IR・出来高・テクニカル指標",
      "collectors": ["financial-data", "stock-price"],
      "sources": {
        "financial-data": {
          "dataPoints": ["revenue", "operating_income", "eps", "guidance"],
          "provider": "edinet"
        },
        "stock-price": {
          "metrics": ["close", "volume", "ma25", "ma75", "rsi"],
          "provider": "yahoo-finance"
        }
      }
    },
    "user": {
      "label": "市場センチメント",
      "description": "SNSセンチメント・掲示板の話題量・投資家心理",
      "collectors": ["sns-sentiment"],
      "sources": {
        "sns-sentiment": {
          "platforms": ["twitter", "yahoo-finance-bbs", "5ch"],
          "keywords": []
        }
      }
    },
    "causal": {
      "label": "因果関係",
      "description": "決算発表→値動き、規制ニュース→セクター反応の自動蓄積",
      "autoMemo": true,
      "validationEnabled": true,
      "learningEnabled": true
    }
  },

  "targets": [
    {
      "id": "7974",
      "name": "任天堂",
      "category": "ゲーム・エンタメ",
      "identifiers": {
        "ticker_jp": "7974.T",
        "edinet_code": "E02460"
      }
    },
    {
      "id": "9684",
      "name": "スクウェア・エニックス",
      "category": "ゲーム・エンタメ",
      "identifiers": {
        "ticker_jp": "9684.T",
        "edinet_code": "E04823"
      }
    },
    {
      "id": "3659",
      "name": "ネクソン",
      "category": "ゲーム・エンタメ",
      "identifiers": {
        "ticker_jp": "3659.T",
        "edinet_code": "E27412"
      }
    }
  ],

  "categories": ["ゲーム・エンタメ", "IT・通信", "広告・メディア"],

  "seasonalPatterns": [
    { "month": 1,  "event": "新年相場・ご祝儀買い",       "impact": "positive", "layer": "macro" },
    { "month": 2,  "event": "3Q決算発表ピーク",           "impact": "neutral",  "layer": "macro" },
    { "month": 3,  "event": "年度末リバランス・配当権利", "impact": "positive", "layer": "macro" },
    { "month": 4,  "event": "新年度・海外勢フロー",      "impact": "positive", "layer": "macro" },
    { "month": 5,  "event": "Sell in May",                "impact": "negative", "layer": "macro" },
    { "month": 6,  "event": "株主総会シーズン",           "impact": "neutral",  "layer": "macro" },
    { "month": 8,  "event": "夏枯れ相場",                "impact": "negative", "layer": "macro" },
    { "month": 9,  "event": "中間配当権利",               "impact": "positive", "layer": "macro" },
    { "month": 11, "event": "2Q決算発表ピーク",           "impact": "neutral",  "layer": "macro" },
    { "month": 12, "event": "掉尾の一振・税金売り",       "impact": "neutral",  "layer": "macro" }
  ],

  "analysis": {
    "anomalyThreshold": 2.5,
    "trendWindow": 5,
    "causationWindowDays": 3,
    "autoConfirmThreshold": 0.70,
    "autoRejectThreshold": 0.25
  },

  "dataPrefix": "stock"
}

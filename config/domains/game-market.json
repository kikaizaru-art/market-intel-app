{
  "domain": "game-market",
  "name": "ゲーム市場分析",
  "version": "1.0.0",
  "description": "モバイルゲーム市場の広告・トレンド・ユーザー反応を多層的に収集・分析",

  "layers": {
    "macro": {
      "label": "マクロ環境",
      "description": "市場全体の潮流 — ジャンルトレンド・業界ニュース",
      "collectors": ["google-trends", "news-rss"],
      "sources": {
        "google-trends": {
          "keywords": ["モンスト", "パズドラ", "ウマ娘", "原神"],
          "geo": "JP"
        },
        "news-rss": {
          "feeds": [
            { "name": "4Gamer", "url": "https://www.4gamer.net/rss/index.xml" },
            { "name": "AUTOMATON", "url": "https://automaton-media.com/feed/" },
            { "name": "Inside", "url": "https://www.inside-games.jp/rss/index.xml" },
            { "name": "GameSpark", "url": "https://www.gamespark.jp/rss/index.xml" }
          ]
        }
      }
    },
    "competitor": {
      "label": "競合動向",
      "description": "他社アプリのストア順位・レビュー",
      "collectors": ["store-reviews", "store-ranking"],
      "sources": {
        "store-reviews": {
          "platform": "google-play"
        },
        "store-ranking": { "rankingDepth": 200 }
      }
    },
    "user": {
      "label": "ユーザー反応",
      "description": "アプリレビュー・コミュニティ活動・SNSセンチメント",
      "collectors": ["store-reviews", "community"],
      "sources": {
        "community": {
          "subreddits": ["gachagaming", "PuzzleAndDragons"],
          "keywords": ["Monster Strike", "Puzzle and Dragons", "Uma Musume"]
        }
      }
    },
    "causal": {
      "label": "因果関係",
      "description": "イベント×トレンド異常値の自動相関検出",
      "autoMemo": true,
      "validationEnabled": true,
      "learningEnabled": true
    }
  },

  "targets": [
    {
      "id": "monster-strike",
      "name": "モンスターストライク",
      "category": "アクションRPG",
      "isMain": true,
      "identifiers": {
        "store_id_ios": "553194370",
        "store_id_android": "jp.co.mixi.monsterstrike"
      }
    },
    {
      "id": "puzzle-dragons",
      "name": "パズル&ドラゴンズ",
      "category": "パズルRPG",
      "identifiers": {
        "store_id_ios": "563474464",
        "store_id_android": "jp.gungho.pad"
      }
    },
    {
      "id": "uma-musume",
      "name": "ウマ娘",
      "category": "育成シミュレーション",
      "identifiers": {
        "store_id_ios": "1325457498",
        "store_id_android": "jp.co.cygames.umamusume"
      }
    }
  ],

  "categories": ["パズル", "RPG", "カジュアル", "ストラテジー", "スポーツ"],
  "competitors": ["mixi", "GungHo", "Cygames", "BANDAI NAMCO"],

  "seasonalPatterns": [
    { "month": 1,  "event": "年末年始特需の終了",     "impact": "negative", "layer": "macro" },
    { "month": 2,  "event": "バレンタインシーズン",   "impact": "positive", "layer": "macro" },
    { "month": 3,  "event": "年度末・卒業シーズン",   "impact": "neutral",  "layer": "macro" },
    { "month": 4,  "event": "新生活シーズン開始",     "impact": "positive", "layer": "macro" },
    { "month": 5,  "event": "GW大型連休",             "impact": "positive", "layer": "macro" },
    { "month": 7,  "event": "夏休みシーズン開始",     "impact": "positive", "layer": "macro" },
    { "month": 8,  "event": "お盆シーズン",           "impact": "positive", "layer": "macro" },
    { "month": 10, "event": "ハロウィンシーズン",     "impact": "positive", "layer": "macro" },
    { "month": 12, "event": "クリスマス・年末商戦",   "impact": "positive", "layer": "macro" }
  ],

  "analysis": {
    "anomalyThreshold": 2.0,
    "trendWindow": 4,
    "causationWindowDays": 7,
    "autoConfirmThreshold": 0.65,
    "autoRejectThreshold": 0.30
  },

  "dataPrefix": "game"
}

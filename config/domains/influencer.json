{
  "domain": "influencer",
  "name": "インフルエンサー分析",
  "version": "0.1.0",
  "description": "YouTube/TikTok/Instagram クリエイターの成長・エンゲージメント・競合環境を多層的に分析し、次の一手を導く",

  "layers": {
    "macro": {
      "label": "マクロ環境",
      "description": "ジャンル全体の検索トレンド・プラットフォーム動向",
      "collectors": ["google-trends", "news-rss"],
      "sources": {
        "google-trends": {
          "keywords": [],
          "geo": "JP",
          "note": "対象のジャンルキーワードを自動設定"
        },
        "news-rss": {
          "feeds": [
            { "name": "Social Blade Blog", "url": "https://socialblade.com/blog/feed/" },
            { "name": "CREATORS STATION", "url": "https://creators-station.jp/feed" },
            { "name": "Tuber Town News", "url": "https://yutura.net/news/feed/" }
          ]
        }
      }
    },
    "competitor": {
      "label": "競合クリエイター",
      "description": "同ジャンルの競合チャンネルの登録者数・再生数・投稿頻度",
      "collectors": ["youtube-channels", "social-stats"],
      "sources": {
        "youtube-channels": {
          "provider": "youtube-data-api-v3",
          "metrics": ["subscribers", "views", "videos", "avg_views"],
          "requiresToken": "YOUTUBE_API_KEY"
        },
        "social-stats": {
          "provider": "social-blade",
          "platforms": ["youtube", "tiktok", "instagram"],
          "metrics": ["follower_growth", "engagement_rate", "post_frequency"]
        }
      }
    },
    "user": {
      "label": "オーディエンス反応",
      "description": "コメントセンチメント・エンゲージメント率・視聴者の声",
      "collectors": ["comment-analysis", "engagement-tracker"],
      "sources": {
        "comment-analysis": {
          "provider": "youtube-data-api-v3",
          "metrics": ["comment_count", "sentiment", "top_topics"],
          "maxComments": 200
        },
        "engagement-tracker": {
          "metrics": ["likes", "comments", "shares", "saves"],
          "platforms": ["youtube", "tiktok", "instagram"]
        }
      }
    },
    "causal": {
      "label": "因果関係",
      "description": "投稿テーマ・時間帯・サムネイル→再生数・登録者変動の因果パターン蓄積",
      "autoMemo": true,
      "validationEnabled": true,
      "learningEnabled": true
    }
  },

  "targets": [
    {
      "id": "hikakin",
      "name": "HIKAKIN",
      "category": "エンタメ",
      "identifiers": {
        "youtube_channel_id": "UCZf__ehlCEBPop-_sldpBUQ",
        "youtube_handle": "@HikakinTV",
        "tiktok_handle": "@hikakin",
        "instagram_handle": "@hikakin"
      }
    },
    {
      "id": "hajime",
      "name": "はじめしゃちょー",
      "category": "エンタメ",
      "identifiers": {
        "youtube_channel_id": "UCgMPP6RRjktV7krOfyUewqw",
        "youtube_handle": "@hajaboriniku",
        "tiktok_handle": "@hajimesyacho"
      }
    },
    {
      "id": "nakata-uni",
      "name": "中田敦彦のYouTube大学",
      "category": "教育",
      "identifiers": {
        "youtube_channel_id": "UCFo4kqllbcQ4nV83WCyraiw",
        "youtube_handle": "@NKTofficial"
      }
    }
  ],

  "categories": [
    "エンタメ",
    "ゲーム実況",
    "教育・ビジネス",
    "美容・ファッション",
    "料理・グルメ",
    "テック・ガジェット",
    "Vlog・ライフスタイル",
    "音楽",
    "スポーツ・フィットネス"
  ],

  "competitors": ["HIKAKIN", "はじめしゃちょー", "中田敦彦", "ヒカル", "コムドット"],

  "seasonalPatterns": [
    { "month": 1,  "event": "年末年始の視聴時間増加・まとめ動画シーズン", "impact": "positive", "layer": "macro" },
    { "month": 3,  "event": "卒業・入学シーズン（自己啓発・教育系UP）",    "impact": "positive", "layer": "macro" },
    { "month": 4,  "event": "新生活シーズン（レビュー・How-to需要増）",    "impact": "positive", "layer": "macro" },
    { "month": 5,  "event": "GW大型連休（エンタメ視聴増）",               "impact": "positive", "layer": "macro" },
    { "month": 6,  "event": "梅雨シーズン（インドア系視聴増）",           "impact": "positive", "layer": "macro" },
    { "month": 7,  "event": "夏休み開始（若年層の視聴時間ピーク）",       "impact": "positive", "layer": "macro" },
    { "month": 8,  "event": "夏休みピーク（コラボ・企画系が強い）",       "impact": "positive", "layer": "macro" },
    { "month": 9,  "event": "新学期開始（視聴時間が一時減少）",           "impact": "negative", "layer": "macro" },
    { "month": 10, "event": "ハロウィン企画シーズン",                     "impact": "positive", "layer": "macro" },
    { "month": 12, "event": "クリスマス・年末企画・ランキング動画",       "impact": "positive", "layer": "macro" }
  ],

  "analysis": {
    "anomalyThreshold": 2.0,
    "trendWindow": 4,
    "causationWindowDays": 7,
    "autoConfirmThreshold": 0.65,
    "autoRejectThreshold": 0.30
  },

  "dataPrefix": "influencer"
}
